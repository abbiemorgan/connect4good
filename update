        textarea:focus,input:focus,select:focus{border-color:${accent}!important;box-shadow:0 0 0 3px ${accent}12!important}
      `}</style>

      <div style={S.container}>
        {/* HEADER */}
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 28 }}>
          <div>
            <span style={{ padding: "3px 10px", borderRadius: 5, background: accent, color: "#fff", fontSize: 9.5, fontWeight: 800, letterSpacing: "0.14em", textTransform: "uppercase" as const, fontFamily: "'Libre Franklin', sans-serif" }}>
              {isCharity ? "Charity" : "Company"}
            </span>
            <h1 style={{ fontSize: 30, fontWeight: 700, color: "#0f172a", fontFamily: "'Lora', serif", margin: "6px 0 0 0", lineHeight: 1.15 }}>
              {isCharity ? "Project Hub" : "Partnership Hub"}
            </h1>
          </div>
          <button onClick={() => { setRole(null); setPage("dashboard"); setRespondingTo(null); }}
            style={{ padding: "7px 16px", borderRadius: 8, border: "1.5px solid #d1d5db", background: "#fff", color: "#6b7280", fontSize: 12, fontWeight: 600, fontFamily: "'Libre Franklin', sans-serif", cursor: "pointer" }}>
            Switch Role
          </button>
        </div>

        {/* NAV */}
        <div style={{ display: "flex", gap: 6, marginBottom: 28, flexWrap: "wrap" }}>
          {navItems.map((n: NavItem) => (
