                fontFamily: "'Libre Franklin', sans-serif", cursor: "pointer", transition: "all 0.15s",
                border: n.special ? "none" : page === n.k ? `2px solid ${accent}` : "1.5px solid #d1d5db",
                background: n.special ? "#16a34a" : page === n.k ? `${accent}0d` : "#fff",
                color: n.special ? "#fff" : page === n.k ? accent : "#6b7280",
