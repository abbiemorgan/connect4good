              {[
                { l: "Projects", n: projects.length, c: "#0f2942" },
                { l: "Open", n: openProjects.length, c: "#2563eb" },
                { l: "Responses", n: responses.length, c: "#7c3aed" },
                { l: "Matched", n: projects.filter((p: Project) => p.projectStatus === "matched").length, c: "#16a34a" },
              ].map((s) => (
                <div key={s.l} style={{ ...S.card, flex: "1 1 0", textAlign: "center" as const, padding: "16px 12px", minWidth: 85 }}>
                  <div style={{ fontSize: 24, fontWeight: 700, color: s.c, fontFamily: "'IBM Plex Mono', monospace" }}>{s.n}</div>
                  <div style={{ fontSize: 11, color: "#9ca3af", fontWeight: 600 }}>{s.l}</div>
                </div>
              ))}
            </div>

            {Object.keys(selectedMatches).length > 0 && (
              <div style={{ ...S.card, border: "2px solid #16a34a", background: "#f0fdf4", marginBottom: 16 }}>
                <div style={{ fontSize: 13, fontWeight: 700, color: "#166534", marginBottom: 8 }}>Confirmed Matches</div>
                {Object.entries(selectedMatches).map(([projId, compId]: [string, string]) => {
                  const proj = projects.find((p: Project) => p.id === projId);
                  const comp = companies.find((c: Company) => c.id === compId);
                  return (
                    <div key={projId} style={{ padding: "8px 0", borderBottom: "1px solid #bbf7d0", fontSize: 13, color: "#1e3a2f" }}>
                      <strong>{proj?.title}</strong> matched with <strong>{comp?.name}</strong>
                    </div>
                  );
                })}
              </div>
            )}

            {projects.length > 0 ? (
              <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
                {projects.map((p: Project) => {
                  const st = STATUSES.find((s: StatusOption) => s.v === p.status);
                  const vol = VOL_TYPES.find((v: VolTypeOption) => v.v === p.volunteeringType);
                  const projResponses = responses.filter((r: CompanyResponse) => r.projectId === p.id);
                  return (
                    <div key={p.id} style={S.card}>
                      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 10 }}>
                        <h3 style={{ fontSize: 16, fontWeight: 700, color: "#0f172a", fontFamily: "'Lora', serif", margin: 0 }}>{p.title}</h3>
                        <div style={{ display: "flex", gap: 6, flexShrink: 0 }}>
                          {st && <Badge label={st.l} color={st.c} bg={st.bg} />}
                          <Badge label={p.projectStatus} color={p.projectStatus === "matched" ? "#16a34a" : "#2563eb"} bg={p.projectStatus === "matched" ? "#f0fdf4" : "#eff6ff"} />
                        </div>
                      </div>
                      <p style={{ fontSize: 13, color: "#4b5563", lineHeight: 1.6, margin: "0 0 12px 0" }}>{p.description}</p>
                      <div style={{ display: "flex", flexWrap: "wrap", gap: 4, marginBottom: 10 }}>
                        {p.essentialSkills.map((s: string) => <SkillTag key={s} skill={s} />)}
                      </div>
                      <div style={{ display: "flex", gap: 14, fontSize: 11.5, color: "#9ca3af", fontWeight: 600, flexWrap: "wrap" }}>
                        <span>{p.startDate} → {p.endDate}</span>
                        <span>{p.peopleNeeded} volunteer{p.peopleNeeded !== 1 ? "s" : ""}</span>
                        {vol && <span>{vol.l}</span>}
                        {projResponses.length > 0 && <span style={{ color: "#7c3aed" }}>{projResponses.length} response{projResponses.length !== 1 ? "s" : ""}</span>}
                      </div>
                      {p.additionalInfo && (
                        <div style={{ marginTop: 10, padding: "10px 12px", borderRadius: 8, background: "#f9fafb", fontSize: 12.5, color: "#4b5563", lineHeight: 1.5, borderLeft: "3px solid #e5e7eb" }}>{p.additionalInfo}</div>
                      )}
                    </div>
                  );
                })}
              </div>
            ) : (
              <div style={{ ...S.card, textAlign: "center" as const, padding: 48, color: "#9ca3af" }}>
                <div style={{ fontSize: 15 }}>No projects yet. Create your first proposal.</div>
              </div>
            )}
          </div>
        )}

        {/* CHARITY: NEW PROJECT */}
        {isCharity && page === "new_project" && (
          <div style={{ ...S.card, padding: "32px 36px", animation: "slideIn 0.3s ease" }}>
            <h2 style={{ fontSize: 22, fontWeight: 700, color: "#0f172a", fontFamily: "'Lora', serif", margin: "0 0 24px 0" }}>New Project Proposal</h2>
            <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
              <div>
                <label style={S.label}>Project Title</label>
                <input style={S.input} value={projForm.title} onChange={(e) => setProjForm({ ...projForm, title: e.target.value })} placeholder="e.g. Community Digital Literacy Programme" maxLength={120} />
              </div>
              <div>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "baseline" }}>
                  <label style={S.label}>Project Description</label>
                  <span style={{ fontSize: 11, fontFamily: "'IBM Plex Mono', monospace", fontWeight: 600, color: projForm.description.length > CHAR_LIMIT * 0.85 ? (projForm.description.length >= CHAR_LIMIT ? "#dc2626" : "#ca8a04") : "#9ca3af" }}>{projForm.description.length}/{CHAR_LIMIT}</span>
                </div>
                <textarea style={{ ...S.input, minHeight: 100, resize: "vertical" as const }} value={projForm.description} onChange={(e) => { if (e.target.value.length <= CHAR_LIMIT) setProjForm({ ...projForm, description: e.target.value }); }} placeholder="Describe your project goals, what support you need, and expected outcomes..." maxLength={CHAR_LIMIT} />
                <div style={{ height: 3, borderRadius: 2, background: "#e5e7eb", marginTop: 5, overflow: "hidden" }}>
                  <div style={{ height: "100%", borderRadius: 2, width: `${Math.min((projForm.description.length / CHAR_LIMIT) * 100, 100)}%`, background: projForm.description.length > CHAR_LIMIT * 0.85 ? "#dc2626" : "#0f2942", transition: "all 0.2s" }} />
                </div>
              </div>
              <div>
                <label style={S.label}>Project Status</label>
                <div style={{ display: "flex", flexWrap: "wrap", gap: 7, marginTop: 6 }}>
                  {STATUSES.map((s: StatusOption) => (
                    <button key={s.v} type="button" onClick={() => setProjForm({ ...projForm, status: s.v })}
                      style={{ padding: "7px 16px", borderRadius: 8, border: projForm.status === s.v ? `2px solid ${s.c}` : "1.5px solid #e5e7eb", background: projForm.status === s.v ? s.bg : "#fff", color: projForm.status === s.v ? s.c : "#9ca3af", fontSize: 12.5, fontWeight: projForm.status === s.v ? 700 : 500, fontFamily: "'Libre Franklin', sans-serif", cursor: "pointer", transition: "all 0.15s" }}>{s.l}</button>
                  ))}
                </div>
              </div>
              <SkillPicker label="Essential Skills" sub="Select the skills needed for this project (minimum 3)" selected={projForm.essentialSkills} onChange={(s: string[]) => setProjForm({ ...projForm, essentialSkills: s })} minRequired={MIN_SKILLS} />
              <div>
                <label style={S.label}>Estimated Support Required</label>
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12, marginTop: 6 }}>
                  <div><div style={{ ...S.sub, marginBottom: 4 }}>Start Date</div><input style={S.input} type="date" value={projForm.startDate} onChange={(e) => setProjForm({ ...projForm, startDate: e.target.value })} /></div>
                  <div><div style={{ ...S.sub, marginBottom: 4 }}>End Date</div><input style={S.input} type="date" value={projForm.endDate} onChange={(e) => setProjForm({ ...projForm, endDate: e.target.value })} /></div>
                  <div><div style={{ ...S.sub, marginBottom: 4 }}>People Needed</div><input style={S.input} type="number" min={1} max={100} value={projForm.peopleNeeded} onChange={(e) => setProjForm({ ...projForm, peopleNeeded: Math.max(1, parseInt(e.target.value) || 1) })} /></div>
                </div>
              </div>
              <div>
                <label style={S.label}>Type of Volunteering</label>
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8, marginTop: 7 }}>
                  {VOL_TYPES.map((v: VolTypeOption) => (
                    <button key={v.v} type="button" onClick={() => setProjForm({ ...projForm, volunteeringType: v.v })}
                      style={{ padding: "12px 14px", borderRadius: 10, textAlign: "left" as const, border: projForm.volunteeringType === v.v ? "2px solid #0f2942" : "1.5px solid #e5e7eb", background: projForm.volunteeringType === v.v ? "#f0f4f8" : "#fff", cursor: "pointer", transition: "all 0.15s" }}>
                      <div style={{ fontWeight: 700, fontSize: 13, color: projForm.volunteeringType === v.v ? "#0f2942" : "#374151", fontFamily: "'Libre Franklin', sans-serif" }}>{v.l}</div>
                      <div style={{ fontSize: 11, color: "#9ca3af", fontFamily: "'Libre Franklin', sans-serif", marginTop: 2 }}>{v.d}</div>
                    </button>
                  ))}
                </div>
              </div>
              <div>
                <label style={S.label}>Additional Information</label>
                <div style={S.sub}>Any other details, requirements, or context you'd like companies to know about</div>
                <textarea style={{ ...S.input, minHeight: 90, resize: "vertical" as const, marginTop: 6 }} value={projForm.additionalInfo} onChange={(e) => setProjForm({ ...projForm, additionalInfo: e.target.value })} placeholder="e.g. We'd prefer a team with prior experience working with vulnerable communities..." />
              </div>
              <div style={{ display: "flex", gap: 10, marginTop: 4 }}>
                <button onClick={createProject} disabled={!projValid} style={{ flex: 1, padding: "12px 24px", borderRadius: 10, border: "none", background: "#0f2942", color: "#fff", fontSize: 14, fontWeight: 700, fontFamily: "'Libre Franklin', sans-serif", cursor: projValid ? "pointer" : "not-allowed", opacity: projValid ? 1 : 0.4 }}>Create Project</button>
                <button onClick={() => { setProjForm(emptyProj); setPage("dashboard"); }} style={{ padding: "12px 24px", borderRadius: 10, border: "1.5px solid #d1d5db", background: "#fff", color: "#6b7280", fontSize: 14, fontWeight: 600, fontFamily: "'Libre Franklin', sans-serif", cursor: "pointer" }}>Cancel</button>
              </div>
            </div>
          </div>
        )}

        {/* CHARITY: REVIEW RESPONSES */}
        {isCharity && page === "review" && (
          <div style={{ animation: "fadeUp 0.3s ease" }}>
            <div style={{ textAlign: "center" as const, marginBottom: 24 }}>
              <h2 style={{ fontSize: 24, fontWeight: 700, color: "#0f172a", fontFamily: "'Lora', serif", margin: 0 }}>Company Responses</h2>
              <p style={{ color: "#9ca3af", fontSize: 13, marginTop: 4 }}>Review responses from interested companies and select your match.</p>
            </div>
            {projects.filter((p: Project) => responses.some((r: CompanyResponse) => r.projectId === p.id)).map((proj: Project) => {
              const ranked = rankResponses(proj, responses, companies);
              return (
                <div key={proj.id} style={{ ...S.card, marginBottom: 16 }}>
                  <h3 style={{ fontSize: 17, fontWeight: 700, color: "#0f172a", fontFamily: "'Lora', serif", margin: "0 0 4px 0" }}>{proj.title}</h3>
                  <div style={{ fontSize: 11.5, color: "#9ca3af", marginBottom: 16 }}>{ranked.length} response{ranked.length !== 1 ? "s" : ""} · {proj.essentialSkills.map((s: string) => s.replace(/_/g, " ")).join(", ")}</div>
                  {ranked.map((r: RankedResponse, i: number) => {
                    const chosen = selectedMatches[proj.id] === r.companyId;
                    const locked = !!selectedMatches[proj.id];
                    return (
                      <div key={r.companyId} style={{ padding: "18px 20px", marginBottom: 10, borderRadius: 12, border: chosen ? "2px solid #16a34a" : "1.5px solid #e5e7eb", background: chosen ? "#f0fdf4" : "#fafbfc" }}>
                        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 10 }}>
                          <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                            <span style={{ width: 24, height: 24, borderRadius: "50%", background: i === 0 ? "#0f2942" : i === 1 ? "#374151" : "#9ca3af", color: "#fff", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 11, fontWeight: 800, fontFamily: "'IBM Plex Mono', monospace" }}>{i + 1}</span>
                            <span style={{ fontWeight: 700, fontSize: 15, color: "#0f172a" }}>{r.companyName}</span>
                          </div>
                          <div style={{ fontSize: 12, fontWeight: 700, color: "#16a34a", fontFamily: "'IBM Plex Mono', monospace" }}>{r.overlap.count}/{r.overlap.total} skills</div>
                        </div>
                        {r.companyBio && <div style={{ fontSize: 12.5, color: "#6b7280", marginBottom: 10, marginLeft: 32, fontStyle: "italic" }}>{r.companyBio}</div>}
                        <div style={{ marginLeft: 32, padding: "10px 14px", borderRadius: 8, background: "#ecfeff", border: "1px solid #a5f3fc", marginBottom: 10 }}>
                          <div style={{ fontSize: 11.5, fontWeight: 700, color: "#0891b2", marginBottom: 4 }}>Meeting Requested</div>
                          <div style={{ fontSize: 12.5, color: "#374151" }}>{r.meetingDate} at {r.meetingTime}{r.meetingNote && <span style={{ color: "#6b7280" }}> — {r.meetingNote}</span>}</div>
                        </div>
                        <div style={{ marginLeft: 32, display: "flex", gap: 14, fontSize: 11.5, color: "#9ca3af", fontWeight: 600, marginBottom: 10, flexWrap: "wrap" }}>
                          <span>{r.peopleAvailable} people available</span>
                          <span>{r.availableFrom} → {r.availableUntil}</span>
                        </div>
                        <div style={{ marginLeft: 32, padding: "10px 12px", borderRadius: 8, background: "#f9fafb", fontSize: 12.5, color: "#4b5563", lineHeight: 1.5, borderLeft: "3px solid #e5e7eb" }}>{r.description}</div>
                        <div style={{ marginLeft: 32, marginTop: 10, display: "flex", flexWrap: "wrap", gap: 4 }}>
                          {proj.essentialSkills.map((s: string) => <SkillTag key={s} skill={s} highlight={r.overlap.matched.includes(s.toLowerCase())} />)}
                        </div>
                        <div style={{ marginTop: 14, marginLeft: 32 }}>
                          {!locked && <button onClick={() => selectMatch(proj.id, r.companyId)} style={{ width: "100%", padding: "10px", borderRadius: 8, border: "none", background: "#16a34a", color: "#fff", fontSize: 13, fontWeight: 700, fontFamily: "'Libre Franklin', sans-serif", cursor: "pointer" }}>Select {r.companyName}</button>}
                          {chosen && <div style={{ textAlign: "center" as const, padding: "8px 0", fontWeight: 700, color: "#166534", fontSize: 13 }}>Matched</div>}
                        </div>
                      </div>
                    );
                  })}
                </div>
              );
            })}
            {!projects.some((p: Project) => responses.some((r: CompanyResponse) => r.projectId === p.id)) && (
              <div style={{ ...S.card, textAlign: "center" as const, padding: 48, color: "#9ca3af" }}><div style={{ fontSize: 15 }}>No responses yet.</div></div>
            )}
            <div style={{ textAlign: "center" as const, marginTop: 12 }}>
              <button onClick={() => setPage("dashboard")} style={{ padding: "10px 24px", borderRadius: 8, border: "1.5px solid #d1d5db", background: "#fff", color: "#6b7280", fontSize: 13, fontWeight: 600, fontFamily: "'Libre Franklin', sans-serif", cursor: "pointer" }}>Back to Dashboard</button>
            </div>
          </div>
        )}

        {/* COMPANY DASHBOARD */}
        {!isCharity && page === "dashboard" && (
          <div style={{ animation: "fadeUp 0.3s ease" }}>
            <div style={{ display: "flex", gap: 10, marginBottom: 20, flexWrap: "wrap" }}>
              {[
                { l: "Your Companies", n: companies.length, c: "#16a34a" },
                { l: "Matched Projects", n: openProjects.length, c: "#2563eb" },
                { l: "Responses Sent", n: responses.length, c: "#7c3aed" },
              ].map((s) => (
                <div key={s.l} style={{ ...S.card, flex: "1 1 0", textAlign: "center" as const, padding: "16px 12px", minWidth: 100 }}>
                  <div style={{ fontSize: 24, fontWeight: 700, color: s.c, fontFamily: "'IBM Plex Mono', monospace" }}>{s.n}</div>
                  <div style={{ fontSize: 11, color: "#9ca3af", fontWeight: 600 }}>{s.l}</div>
                </div>
              ))}
            </div>
            {Object.keys(compNotifs).length > 0 && (
              <div style={{ ...S.card, border: "2px solid #16a34a", background: "#f0fdf4", marginBottom: 16 }}>
                <div style={{ fontSize: 13, fontWeight: 700, color: "#166534", marginBottom: 8 }}>You've Been Matched!</div>
                {Object.entries(compNotifs).map(([cid, titles]: [string, string[]]) => {
                  const comp = companies.find((c: Company) => c.id === cid);
                  return titles.map((t: string, i: number) => (
                    <div key={`${cid}-${i}`} style={{ padding: "8px 0", borderBottom: "1px solid #bbf7d0", fontSize: 13, color: "#1e3a2f" }}>
                      <strong>{comp?.name}</strong> has been selected for <strong>"{t}"</strong>
                    </div>
                  ));
                })}
              </div>
            )}
            {companies.length > 0 ? (
              <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
                {companies.map((c: Company) => (
                  <div key={c.id} style={S.card}>
                    <div style={{ fontWeight: 700, fontSize: 16, color: "#0f172a", fontFamily: "'Lora', serif" }}>{c.name}</div>
                    {c.bio && <p style={{ fontSize: 13, color: "#4b5563", lineHeight: 1.5, margin: "6px 0 10px 0" }}>{c.bio}</p>}
                    <div style={{ display: "flex", flexWrap: "wrap", gap: 4, marginTop: c.bio ? 0 : 8, marginBottom: 8 }}>
                      {c.offeredSkills.map((s: string) => <span key={s} style={{ padding: "2px 9px", borderRadius: 12, fontSize: 11, fontWeight: 600, background: "#f0fdf4", color: "#166534" }}>{s.replace(/_/g, " ")}</span>)}
                    </div>
                    <div style={{ fontSize: 11.5, color: "#9ca3af", fontWeight: 600 }}>
                      {c.offeredSkills.length} skill{c.offeredSkills.length !== 1 ? "s" : ""} offered
                      {c.preferredProjectIds.length > 0 && <span style={{ color: "#16a34a" }}> · Responded to {c.preferredProjectIds.length} project{c.preferredProjectIds.length !== 1 ? "s" : ""}</span>}
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div style={{ ...S.card, textAlign: "center" as const, padding: 48, color: "#9ca3af" }}><div style={{ fontSize: 15 }}>No companies registered yet.</div></div>
            )}
          </div>
        )}

        {/* COMPANY: REGISTER */}
        {!isCharity && page === "register" && (
          <div style={{ ...S.card, padding: "32px 36px", animation: "slideIn 0.3s ease" }}>
            <h2 style={{ fontSize: 22, fontWeight: 700, color: "#0f172a", fontFamily: "'Lora', serif", margin: "0 0 24px 0" }}>Register Company</h2>
            <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
              <div><label style={S.label}>Company Name</label><input style={S.input} value={compForm.name} onChange={(e) => setCompForm({ ...compForm, name: e.target.value })} placeholder="e.g. TechForGood Ltd" /></div>
              <div>
                <label style={S.label}>Company Bio</label>
                <div style={S.sub}>Tell charities a bit about your company and what drives you</div>
                <textarea style={{ ...S.input, minHeight: 90, resize: "vertical" as const, marginTop: 6 }} value={compForm.bio} onChange={(e) => setCompForm({ ...compForm, bio: e.target.value })} placeholder="e.g. We're a London-based tech consultancy passionate about using technology for social good..." />
              </div>
              <SkillPicker label="Skills You Can Offer" sub="Select all skills your team can provide" selected={compForm.offeredSkills} onChange={(s: string[]) => setCompForm({ ...compForm, offeredSkills: s })} />
              <div style={{ display: "flex", gap: 10 }}>
                <button onClick={createCompany} disabled={!compForm.name.trim() || compForm.offeredSkills.length === 0}
                  style={{ flex: 1, padding: "12px 24px", borderRadius: 10, border: "none", background: "#16a34a", color: "#fff", fontSize: 14, fontWeight: 700, fontFamily: "'Libre Franklin', sans-serif", cursor: "pointer", opacity: (!compForm.name.trim() || compForm.offeredSkills.length === 0) ? 0.4 : 1 }}>Register</button>
                <button onClick={() => { setCompForm(emptyComp); setPage("dashboard"); }} style={{ padding: "12px 24px", borderRadius: 10, border: "1.5px solid #d1d5db", background: "#fff", color: "#6b7280", fontSize: 14, fontWeight: 600, fontFamily: "'Libre Franklin', sans-serif", cursor: "pointer" }}>Cancel</button>
              </div>
            </div>
          </div>
        )}

        {/* COMPANY: BROWSE + RESPONSE FORM */}
        {!isCharity && page === "browse" && (
          <div style={{ animation: "fadeUp 0.3s ease" }}>
            {companies.length === 0 ? (
              <div style={{ ...S.card, textAlign: "center" as const, padding: 40, color: "#9ca3af" }}>Register a company first to browse projects.</div>
            ) : respondingTo ? (() => {
              const proj = projects.find((p: Project) => p.id === respondingTo.projectId);
              const comp = companies.find((c: Company) => c.id === respondingTo.companyId);
              if (!proj || !comp) return null;
              return <ProjectResponseForm project={proj} company={comp} onSubmit={submitResponse} onCancel={() => setRespondingTo(null)} />;
            })() : (
              companies.map((comp: Company) => {
                const matched = getMatchedProjects(projects, comp);
                const alreadyResponded = new Set(responses.filter((r: CompanyResponse) => r.companyId === comp.id).map((r: CompanyResponse) => r.projectId));
                return (
                  <div key={comp.id} style={{ ...S.card, marginBottom: 16 }}>
                    <h3 style={{ fontSize: 17, fontWeight: 700, color: "#0f172a", fontFamily: "'Lora', serif", margin: "0 0 4px 0" }}>{comp.name}</h3>
                    <p style={{ fontSize: 12.5, color: "#9ca3af", marginBottom: 14 }}>Projects matching your skills ({matched.length} found)</p>
                    {matched.length === 0 ? (
                      <div style={{ color: "#9ca3af", fontSize: 13, padding: "12px 0" }}>No projects match your current skills yet.</div>
                    ) : (
                      matched.map((proj: ProjectWithOverlap) => {
                        const responded = alreadyResponded.has(proj.id);
                        const vol = VOL_TYPES.find((v: VolTypeOption) => v.v === proj.volunteeringType);
                        return (
                          <div key={proj.id} style={{ padding: "16px 18px", marginBottom: 8, borderRadius: 10, border: responded ? "1.5px solid #bbf7d0" : "1.5px solid #e5e7eb", background: responded ? "#f0fdf4" : "#fff", transition: "all 0.15s" }}>
                            <div style={{ fontWeight: 700, fontSize: 14, color: "#0f172a", marginBottom: 4 }}>{proj.title}</div>
                            <p style={{ fontSize: 12.5, color: "#6b7280", lineHeight: 1.5, margin: "0 0 8px 0" }}>{proj.description}</p>
                            <div style={{ display: "flex", flexWrap: "wrap", gap: 4, marginBottom: 6 }}>
                              {proj.essentialSkills.map((s: string) => <SkillTag key={s} skill={s} highlight={proj.overlap.matched.includes(s.toLowerCase())} />)}
                            </div>
                            <div style={{ fontSize: 11.5, color: "#9ca3af", fontWeight: 600, display: "flex", gap: 12, flexWrap: "wrap" }}>
                              <span>{proj.startDate} → {proj.endDate}</span>
                              <span>{proj.peopleNeeded} people</span>
                              {vol && <span>{vol.l}</span>}
                              <span style={{ color: "#16a34a" }}>{proj.overlap.count}/{proj.overlap.total} skills matched</span>
                            </div>
                            <div style={{ marginTop: 12 }}>
                              {responded ? (
                                <div style={{ fontSize: 12.5, fontWeight: 700, color: "#166534", textAlign: "center" as const, padding: "6px 0" }}>Response Submitted</div>
                              ) : (
                                <button onClick={() => setRespondingTo({ projectId: proj.id, companyId: comp.id })}
                                  style={{ width: "100%", padding: "10px", borderRadius: 8, border: "none", background: "#16a34a", color: "#fff", fontSize: 13, fontWeight: 700, fontFamily: "'Libre Franklin', sans-serif", cursor: "pointer" }}>Respond to Project</button>
                              )}
                            </div>
                          </div>
                        );
                      })
                    )}
                  </div>
                );
              })
            )}
          </div>
        )}
      </div>
    </div>
  );
}

