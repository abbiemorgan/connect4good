// =============================================================================
// MATCHING: skill overlap filter
// =============================================================================

function getSkillOverlap(projectSkills: string[], companySkills: string[]): SkillOverlap {
  const proj = new Set(projectSkills.map((s: string) => s.toLowerCase()));
  const comp = new Set(companySkills.map((s: string) => s.toLowerCase()));
  const matched = [...proj].filter((s: string) => comp.has(s));
  return { matched, count: matched.length, total: proj.size };
}

function getMatchedProjects(projects: Project[], company: Company): ProjectWithOverlap[] {
  return projects
    .filter((p: Project) => p.projectStatus === "open")
    .map((p: Project) => {
      const overlap = getSkillOverlap(p.essentialSkills, company.offeredSkills);
      return { ...p, overlap };
    })
    .filter((p: ProjectWithOverlap) => p.overlap.count > 0)
    .sort((a: ProjectWithOverlap, b: ProjectWithOverlap) => b.overlap.count - a.overlap.count);
}

function rankResponses(project: Project, responses: CompanyResponse[], companies: Company[]): RankedResponse[] {
  return responses
    .filter((r: CompanyResponse) => r.projectId === project.id)
    .map((r: CompanyResponse) => {
      const comp = companies.find((c: Company) => c.id === r.companyId);
      const overlap = getSkillOverlap(project.essentialSkills, comp?.offeredSkills || []);
      return { ...r, companyName: comp?.name || "Unknown", companyBio: comp?.bio || "", overlap };
    })
    .sort((a: RankedResponse, b: RankedResponse) => b.overlap.count - a.overlap.count);
}

