// =============================================================================
// MATCHING ENGINE
// =============================================================================

function computeSkillsScore(
  essential: string[],
  offered: string[],
): { score: number; matched: string[]; missing: string[] } {
  const ess = new Set(essential.map((s) => s.toLowerCase()));
  const off = new Set(offered.map((s) => s.toLowerCase()));
  const intersection = new Set([...ess].filter((s) => off.has(s)));
  const union = new Set([...ess, ...off]);
  if (union.size === 0) return { score: 0, matched: [], missing: [] };
  const score = intersection.size / union.size;
  const missing = [...ess].filter((s) => !off.has(s));
  return {
    score: Math.round(score * 1e4) / 1e4,
    matched: [...intersection].sort(),
    missing: missing.sort(),
  };
}

function computeHeadcount(needed: number, available: number): number {
  if (needed <= 0) return 1;
  return Math.round(Math.min(available / needed, 1) * 1e4) / 1e4;
}

function computeTimeframe(
  pStart: string | Date,
  pEnd: string | Date,
  cFrom: string | Date,
  cUntil: string | Date,
): number {
  const ps = new Date(pStart);
  const pe = new Date(pEnd);
  const cf = new Date(cFrom);
  const cu = new Date(cUntil);
  const os = new Date(Math.max(ps.getTime(), cf.getTime()));
  const oe = new Date(Math.min(pe.getTime(), cu.getTime()));
  const od = Math.max(0, (oe.getTime() - os.getTime()) / 864e5 + 1);
  const pd = Math.max(1, (pe.getTime() - ps.getTime()) / 864e5 + 1);
  return Math.round(Math.min(od / pd, 1) * 1e4) / 1e4;
}

function runMatching(
  project: Project,
  companies: Company[],
  topN = 3,
): MatchResult[] {
  const eligible = companies.filter((c) => {
    if (c.status !== "available") return false;
    if (!c.preferredProjectIds.includes(project.id)) return false;
    return true;
  });

  const scored = eligible.map((c) => {
    const sk = computeSkillsScore(project.essentialSkills, c.offeredSkills);
    return {
      companyId: c.id,
      companyName: c.name,
      overall: Math.round(sk.score * 100) / 100,
      skillsScore: sk.score,
      matchedSkills: sk.matched,
      missingSkills: sk.missing,
    };
  });
  scored.sort((a, b) => b.overall - a.overall);
  return scored.slice(0, topN);
}

